{
  "expo": {
    "name": "BlockQuest - Retro Arcade",
    "slug": "blockquest-retro-arcade",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "blockquest",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "owner": "your-expo-account",
    
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.blockquest.retroarcade",
      "buildNumber": "1",
      "config": {
        "usesNonExemptEncryption": false
      },
      "infoPlist": {
        "NSCameraUsageDescription": "Take screenshots of your high scores to share",
        "NSPhotoLibraryUsageDescription": "Save achievement badges to your photos",
        "NSMicrophoneUsageDescription": "Voice chat with other players",
        "ITSAppUsesNonExemptEncryption": false,
        "UIBackgroundModes": []
      },
      "privacyManifests": {
        "NSPrivacyAccessedAPITypes": [
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryUserDefaults",
            "NSPrivacyAccessedAPITypeReasons": ["CA92.1"]
          }
        ]
      }
    },
    
    "android": {
      "package": "com.blockquest.retroarcade",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0A0E14"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "INTERNET",
        "VIBRATE"
      ],
      "blockedPermissions": [
        "RECORD_AUDIO",
        "CAMERA",
        "READ_CONTACTS",
        "WRITE_CONTACTS",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ]
    },
    
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0A0E14"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 34,
            "targetSdkVersion": 34,
            "minSdkVersion": 24
          },
          "ios": {
            "deploymentTarget": "14.0"
          }
        }
      ]
    ],
    
    "experiments": {
      "typedRoutes": true
    },
    
    "extra": {
      "eas": {
        "projectId": "your-eas-project-id"
      }
    },
    
    "runtimeVersion": {
      "policy": "appVersion"
    },
    
    "updates": {
      "url": "https://u.expo.dev/your-project-id",
      "enabled": true,
      "fallbackToCacheTimeout": 0
    }
  }
}
